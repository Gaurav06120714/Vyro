{
  "name": "vyro-browser",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @vyro/api db:migrate",
    "db:studio": "pnpm --filter @vyro/api db:studio",
    "clean": "turbo run clean && rm -rf node_modules",
    "browse": "tsx scripts/browse.ts",
    "browse:saved": "tsx scripts/browse-persistent.ts"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0",
    "tsx": "^4.11.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
