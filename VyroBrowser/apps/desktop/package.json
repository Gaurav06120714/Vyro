{
  "name": "vyro-browser",
  "version": "1.0.0",
  "description": "Vyro — Your personal AI-powered desktop browser",
  "author": "Vyro Browser",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "npm run package",
    "package": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "package:dir": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --dir",
    "install-app": "npm run package:dir && cp -r dist/mac-arm64/Vyro.app /Applications/Vyro.app && echo 'Vyro installed to /Applications'",
    "release": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --publish=never"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.vyro.browser",
    "productName": "Vyro",
    "copyright": "Copyright © 2025 Vyro Browser",
    "asar": true,
    "asarUnpack": ["assets/**"],
    "files": [
      "main/**",
      "renderer/**",
      "assets/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "dir", "arch": ["arm64"] }
      ],
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "Vyro Browser",
      "icon": "assets/icon.icns",
      "background": "assets/dmg-bg.png",
      "iconSize": 128,
      "contents": [
        { "x": 200, "y": 180, "type": "file" },
        { "x": 520, "y": 180, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 720, "height": 400 }
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "extraResources": [
      { "from": "assets/icon.png", "to": "icon.png" }
    ]
  }
}
