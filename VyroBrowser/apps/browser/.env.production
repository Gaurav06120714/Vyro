# ── Production values (baked into release builds) ────────────────────────────
ELECTRON_IS_DEV=0
NODE_ENV=production

OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2
ENABLE_TELEMETRY=false

LOG_LEVEL=warn
VITE_APP_VERSION=2.1.0
VITE_APP_NAME=Vyro

# ── Windows (Portable) ────────────────────────────────────────────────────────
# Set automatically by the NSIS portable installer — do not set manually.
# PORTABLE_EXECUTABLE_DIR=C:\Users\YourName\Desktop
