{
  "name": "vyro-browser",
  "version": "2.1.0",
  "description": "Vyro — AI-powered desktop browser",
  "author": "Vyro Browser <hello@vyrobrowser.app>",
  "main": "dist-main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "icons:generate": "node resources/icons/generate-icons.mjs",
    "package": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "package:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder -mwl",
    "package:dir": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --dir",
    "package:win:dir": "npm run build && electron-builder --win --dir",
    "install-app": "npm run package:dir && cp -r dist/mac-arm64/Vyro.app /Applications/Vyro.app && echo 'Installed to /Applications/Vyro.app'",
    "install-app:win": "npm run package:win:dir && node scripts/install-windows.mjs",
    "postinstall": "electron-builder install-app-deps",
    "bootstrap": "node src/scripts/ecosystem-bootstrap.mjs"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.31.0",
    "@mozilla/readability": "^0.5.0",
    "@supabase/supabase-js": "^2.106.1",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.3.0",
    "framer-motion": "^11.0.0",
    "jsdom": "^24.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^9.0.0",
    "zod": "^3.22.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.vyro.browser",
    "productName": "Vyro",
    "copyright": "Copyright © 2025 Vyro Browser",
    "asar": true,
    "asarUnpack": [
      "assets/**",
      "node_modules/better-sqlite3/**",
      "node_modules/@cliqz/adblocker-electron/**"
    ],
    "files": [
      "dist-main/**",
      "dist-renderer/**",
      "assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Gaurav06120714",
        "repo": "VyroBrowser",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0",
      "artifactName": "Vyro-macOS-${arch === 'arm64' ? 'AppleSilicon' : 'Intel'}-${version}.${ext}",
      "extendInfo": {
        "NSHighResolutionCapable": true,
        "CFBundleIconFile": "icon"
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "executableName": "Vyro",
      "artifactName": "Vyro-Setup-Windows-x64-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Vyro Browser"
    },
    "linux": {
      "icon": "assets/icons/",
      "artifactName": "Vyro-Linux-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network;WebBrowser",
      "description": "AI-first desktop browser powered by Ollama",
      "desktop": {
        "Name": "Vyro Browser",
        "Comment": "AI-first desktop browser",
        "Categories": "Network;WebBrowser;"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "menuCategory": true,
      "differentialPackage": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vyro",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "warningsAsErrors": false,
      "deleteAppDataOnUninstall": false,
      "license": "LICENSE",
      "artifactName": "Vyro-Setup-Windows-x64-${version}.${ext}"
    },
    "dmg": {
      "title": "Install Vyro Browser",
      "icon": "assets/icon.icns",
      "backgroundColor": "#1a1a2e",
      "iconSize": 160,
      "iconTextSize": 13,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 170,
          "type": "file"
        },
        {
          "x": 480,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "appImage": {
      "artifactName": "Vyro-Linux-${version}-x86_64.AppImage"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    }
  }
}
