# ─────────────────────────────────────────────────────────────────────────────
# Vyro Browser — Environment Variables
# Copy this file to .env and fill in values.
# VITE_* vars are injected into the renderer at build time.
# All others are main-process / Node.js only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Electron ──────────────────────────────────────────────────────────────────
ELECTRON_IS_DEV=1
NODE_ENV=development

# ── Ollama ────────────────────────────────────────────────────────────────────
# Base URL of your local Ollama instance.
# macOS / Linux: http://localhost:11434  (default)
# Windows:       http://localhost:11434  (same — Ollama for Windows uses the same port)
OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Default model loaded on first launch
DEFAULT_MODEL=llama3.2

# ── Features ──────────────────────────────────────────────────────────────────
# Set to true to send anonymous crash/usage reports (default: false)
ENABLE_TELEMETRY=false

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | silent
LOG_LEVEL=debug

# ── App metadata (injected into renderer) ─────────────────────────────────────
VITE_APP_VERSION=2.1.0
VITE_APP_NAME=Vyro

# ── Supabase sync (optional) ──────────────────────────────────────────────────
# Create a free project at https://supabase.com and paste your values here.
# Leave blank to run in local-only mode (no sync).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx   # new format (preferred)
# VITE_SUPABASE_ANON_KEY=eyJ...                     # legacy format also supported

# ── Windows (Portable build only) ─────────────────────────────────────────────
# Set automatically by the NSIS portable installer.
# When set, userData is isolated to %PORTABLE_EXECUTABLE_DIR%\VyroData
# so the portable .exe never writes to %APPDATA%.
# Do NOT set this manually — the portable installer injects it at launch.
# PORTABLE_EXECUTABLE_DIR=C:\Users\YourName\Desktop
